PORT=8080
NODE_ENV=development
FRONTEND_ORIGIN="http://localhost:3000"

# Express JWT auth. This is not Supabase Auth.
JWT_SECRET="replace-with-a-long-random-secret-at-least-32-chars"

ADMIN_EMAILS="admin1@gmail.com,admin2@gmail.com"
ADMIN_DEFAULT_PASSWORD="admin_pass"

# Supabase Postgres.
# Use the transaction pooler URL for runtime server connections.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Use a direct/session connection for Prisma migrations if your workflow needs it.
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres"

# Supabase Storage.
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_ANON_KEY="replace-with-publishable-or-anon-key"
SUPABASE_SERVICE_ROLE_KEY="replace-with-service-role-or-secret-key"
PAYMENT_SLIPS_BUCKET="payment-slips"
# Optional when API and frontend are deployed on sibling domains.
# COOKIE_DOMAIN=".example.com"
